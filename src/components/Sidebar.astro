---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

// Group posts by subject
const subjects: Record<string, typeof posts> = {};
posts.forEach(post => {
  const subject = post.data.subject;
  if (!subjects[subject]) {
    subjects[subject] = [];
  }
  subjects[subject].push(post);
});

// Sort subjects alphabetically, sort posts within each subject by order
const sortedSubjects = Object.keys(subjects).sort();
sortedSubjects.forEach(key => {
  subjects[key].sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
});

// Get current page path
const currentPath = Astro.url.pathname;
---

<div class="sidebar-backdrop" id="sidebar-backdrop" aria-hidden="true"></div>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-inner">
    <div class="sidebar-header">
      <span class="sidebar-label">Contents</span>
    </div>

    <nav class="sidebar-nav" id="sidebar-nav" aria-label="Blog navigation">
      {sortedSubjects.map((subject) => (
        <details class="subject-group" open>
          <summary class="subject-title" id={`subject-${subject.toLowerCase().replace(/\s+/g, '-')}`}>
            <svg class="chevron-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
            <span>{subject}</span>
          </summary>
          <ul class="subject-links">
            {subjects[subject].map((post) => {
              const postPath = `/blog/${post.id}`;
              const isActive = currentPath === postPath || currentPath === `${postPath}/`;
              return (
                <li>
                  <a 
                    href={postPath} 
                    class:list={['subject-link', { 'is-active': isActive }]}
                    id={`sidebar-link-${post.id}`}
                    data-post-id={post.id}
                  >
                    {post.data.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </details>
      ))}
    </nav>
  </div>
</aside>

<style>
  .sidebar {
    position: fixed;
    top: var(--nav-height);
    left: 0;
    width: var(--sidebar-width);
    height: calc(100vh - var(--nav-height));
    overflow-y: auto;
  
    background: transparent;
    z-index: 50;
  }

  .sidebar-inner {
    padding: var(--spacing-lg) 0;
  }

  .sidebar-header {
    padding: 0 var(--spacing-lg) var(--spacing-md);
    margin-bottom: var(--spacing-sm);
  }

  .sidebar-label {
    font-size: clamp(0.6rem, 0.85vw, 0.75rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
  }

  .subject-group {
    margin-bottom: var(--spacing-sm);
  }

  .subject-group[open] > .subject-title .chevron-icon {
    transform: rotate(90deg);
  }

  .subject-title {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    font-size: clamp(0.7rem, 1vw, 0.8125rem);
    font-weight: 600;
    color: var(--text);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: color var(--transition-fast);
    border-radius: var(--radius-sm);
  }

  .subject-title::-webkit-details-marker {
    display: none;
  }

  .subject-title:hover {
    color: var(--text-secondary);
  }

  .chevron-icon {
    flex-shrink: 0;
    transition: transform var(--transition-base);
    color: var(--text-faint);
  }

  /* Vertical track line container */
  .subject-links {
    position: relative;
    padding: var(--spacing-xs) 0;
    margin-left: calc(var(--spacing-lg) + 5px);
    border-left: 1px solid var(--border);
  }

  .subject-link {
    display: block;
    padding: 4px var(--spacing-md) 4px var(--spacing-md);
    margin-left: -1px;
    font-size: clamp(0.65rem, 0.95vw, 0.78rem);
    color: var(--text-muted);
    transition: color var(--transition-fast), border-left-color var(--transition-fast),
                box-shadow var(--transition-fast), text-shadow var(--transition-fast);
    border-left: 2px solid transparent;
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
  }

  .subject-link:hover {
    color: var(--text-secondary);
    border-left-color: var(--text-faint);
  }

  .subject-link.is-active {
    color: var(--accent);
    font-weight: 500;
    border-left-color: var(--accent);
    box-shadow: -2px 0 8px rgba(94, 234, 212, 0.35);
    text-shadow: 0 0 12px rgba(94, 234, 212, 0.5);
  }

  .sidebar-backdrop {
    display: none;
    position: fixed;
    inset: var(--nav-height) 0 0 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
    z-index: 80;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .sidebar-backdrop.is-open {
    display: block;
    opacity: 1;
  }
</style>

<script>
  // Mobile sidebar close helpers
  const sidebarEl = document.getElementById('sidebar');
  const backdropEl = document.getElementById('sidebar-backdrop');

  const closeSidebar = () => {
    sidebarEl?.classList.remove('is-open');
    backdropEl?.classList.remove('is-open');
  };

  backdropEl?.addEventListener('click', closeSidebar);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && sidebarEl?.classList.contains('is-open')) {
      closeSidebar();
    }
  });

  // Close sidebar when navigating to a post on mobile
  sidebarEl?.querySelectorAll('.subject-link').forEach((link) => {
    link.addEventListener('click', () => {
      if (window.matchMedia('(max-width: 900px)').matches) {
        closeSidebar();
      }
    });
  });

  // Client-side search filtering
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const sidebarNav = document.getElementById('sidebar-nav');

  if (searchInput && sidebarNav) {
    searchInput.addEventListener('input', () => {
      const query = searchInput.value.toLowerCase().trim();
      const groups = sidebarNav.querySelectorAll('.subject-group');

      groups.forEach((group) => {
        const links = group.querySelectorAll('.subject-link');
        let hasVisible = false;

        links.forEach((link) => {
          const text = link.textContent?.toLowerCase() || '';
          const li = link.parentElement;
          if (!li) return;

          if (!query || text.includes(query)) {
            li.style.display = '';
            hasVisible = true;
          } else {
            li.style.display = 'none';
          }
        });

        (group as HTMLElement).style.display = hasVisible || !query ? '' : 'none';
        if (query && hasVisible) {
          group.setAttribute('open', '');
        }
      });
    });
  }
</script>
