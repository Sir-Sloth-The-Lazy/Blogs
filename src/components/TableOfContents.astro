---
export interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{tocHeadings.length > 0 && (
  <aside class="toc-panel" id="toc-panel">
    <div class="toc-inner">
      <span class="toc-label">On this page</span>
      <nav class="toc-nav" id="toc-nav" aria-label="Table of contents">
        <ul class="toc-list">
          {tocHeadings.map((heading) => (
            <li class={`toc-item depth-${heading.depth}`}>
              <a
                href={`#${heading.slug}`}
                class="toc-link"
                data-heading-slug={heading.slug}
                id={`toc-link-${heading.slug}`}
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </aside>
)}

<style>
  .toc-panel {
    position: fixed;
    top: var(--nav-height);
    right: 0;
    width: var(--details-width);
    height: calc(100vh - var(--nav-height));
    overflow-y: auto;
    padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-xl) var(--spacing-md);
    background: transparent;
  }

  .toc-inner {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .toc-label {
    font-size: clamp(0.72rem, 1vw, 0.85rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .toc-list {
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--border);
  }

  .toc-item {
    position: relative;
  }

  .toc-link {
    display: block;
    padding: 4px var(--spacing-sm) 4px var(--spacing-md);
    margin-left: -1px;
    font-size: clamp(0.65rem, 0.95vw, 0.78rem);
    color: var(--text-muted);
    line-height: 1.5;
    transition: color var(--transition-fast), border-left-color var(--transition-fast),
                text-shadow var(--transition-fast), box-shadow var(--transition-fast);
    border-left: 2px solid transparent;
  }

  .toc-link:hover {
    color: var(--text-secondary);
    border-left-color: var(--text-faint);
  }

  .toc-link.is-active {
    color: var(--accent);
    font-weight: 500;
    border-left-color: var(--accent);
    box-shadow: -2px 0 8px rgba(94, 234, 212, 0.35);
    text-shadow: 0 0 12px rgba(94, 234, 212, 0.5);
  }

  .depth-3 .toc-link {
    padding-left: calc(var(--spacing-md) + var(--spacing-sm));
    font-size: clamp(0.6rem, 0.85vw, 0.72rem);
  }
</style>

<script>
  function initScrollSpy() {
    const tocLinks = document.querySelectorAll('.toc-link');
    if (tocLinks.length === 0) return;

    const headingSlugs = Array.from(tocLinks).map(
      (link) => (link as HTMLElement).dataset.headingSlug!
    );

    const headingElements = headingSlugs
      .map((slug) => document.getElementById(slug))
      .filter(Boolean) as HTMLElement[];

    if (headingElements.length === 0) return;

    // Set first link active on load
    tocLinks[0]?.classList.add('is-active');

    function onScroll() {
      const navHeight = parseFloat(getComputedStyle(document.documentElement)
        .getPropertyValue('--nav-height')) || 56;
      const offset = navHeight + 80;

      let current = headingSlugs[0];
      for (let i = 0; i < headingElements.length; i++) {
        if (headingElements[i].getBoundingClientRect().top <= offset) {
          current = headingSlugs[i];
        } else {
          break;
        }
      }

      tocLinks.forEach((link) => {
        const slug = (link as HTMLElement).dataset.headingSlug;
        link.classList.toggle('is-active', slug === current);
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  document.addEventListener('DOMContentLoaded', initScrollSpy);
  document.addEventListener('astro:page-load', initScrollSpy);
</script>
