---
export interface Props {
  author?: string;
  updatedDate?: Date;
  prev?: { title: string; href: string } | null;
  next?: { title: string; href: string } | null;
}

const { author, updatedDate, prev = null, next = null } = Astro.props;

const formattedDate = updatedDate?.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<footer class="site-footer">
  {(author || updatedDate) && (
    <div class="footer-meta">
      {author && (
        <span class="footer-author">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="var(--accent)" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
          </svg>
          Compiled by: <strong>{author}</strong>
        </span>
      )}
      {formattedDate && (
        <span class="footer-updated">Last updated: {formattedDate}</span>
      )}
    </div>
  )}

  {(prev || next) && (
    <nav class="footer-nav" aria-label="Post navigation">
      <div class="footer-nav-prev">
        {prev && (
          <a href={prev.href} class="footer-nav-link">
            <span class="footer-nav-label">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 12H5"/><path d="m12 5-7 7 7 7"/>
              </svg>
              Previous
            </span>
            <span class="footer-nav-title">{prev.title}</span>
          </a>
        )}
      </div>
      <div class="footer-nav-next">
        {next && (
          <a href={next.href} class="footer-nav-link footer-nav-link--right">
            <span class="footer-nav-label">
              Next
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </span>
            <span class="footer-nav-title">{next.title}</span>
          </a>
        )}
      </div>
    </nav>
  )}

  <div class="footer-links">
    <a href="#" class="footer-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
      </svg>
      Contribute
    </a>
    <a href="#" class="footer-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      Community
    </a>
    <a href="#" class="footer-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      Sponsor
    </a>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--spacing-2xl);
    border-top: 1px solid var(--border-light);
    padding-top: var(--spacing-xl);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  /* Author + date row */
  .footer-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .footer-author {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .footer-author strong {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .footer-updated {
    font-size: var(--text-sm);
    color: var(--text-faint);
  }

  /* Prev / Next nav */
  .footer-nav {
    display: flex;
    justify-content: space-between;
    gap: var(--spacing-lg);
  }

  .footer-nav-prev,
  .footer-nav-next {
    flex: 1;
  }

  .footer-nav-next {
    display: flex;
    justify-content: flex-end;
  }

  .footer-nav-link {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--spacing-md);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-secondary);
    transition: border-color var(--transition-fast), background var(--transition-fast);
    max-width: 260px;
    width: 100%;
  }

  .footer-nav-link:hover {
    border-color: var(--accent);
    background: var(--highlight);
  }

  .footer-nav-link--right {
    align-items: flex-end;
  }

  .footer-nav-label {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-xs);
    color: var(--text-faint);
  }

  .footer-nav-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text);
    line-height: var(--line-height-tight);
  }

  /* Contribute / Community / Sponsor */
  .footer-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-xl);
    padding: var(--spacing-lg) 0;
    border-top: 1px solid var(--border-light);
  }

  .footer-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    color: var(--text-faint);
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--text-secondary);
  }
</style>
