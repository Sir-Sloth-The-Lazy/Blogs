---
// Navbar component — fixed top bar with site title, search, and social icons
---

<nav class="navbar" id="main-nav">
  <div class="navbar-inner">
    <!-- Mobile menu button -->
    <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <!-- Site title -->
    <a href="/" class="navbar-brand" id="nav-home">
      blog<span class="brand-dot">.</span>
    </a>

    <!-- Search bar -->
    <div class="navbar-search" id="nav-search-container">
      <svg class="search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.35-4.35"></path>
      </svg>
      <input 
        type="text" 
        class="search-input" 
        id="search-input" 
        placeholder="Search posts..." 
        autocomplete="off"
        spellcheck="false"
      />
      <kbd class="search-shortcut">/</kbd>
    </div>

    <!-- Social icons -->
    <div class="navbar-icons" id="nav-social-icons">
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="nav-icon" id="nav-linkedin" aria-label="LinkedIn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="nav-icon" id="nav-github" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--nav-height);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    z-index: 100;
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    background: rgba(3, 7, 18, 0.45);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 var(--spacing-lg);
    max-width: 100%;
    gap: var(--spacing-lg);
  }

  .mobile-menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--text-muted);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .mobile-menu-btn:hover {
    color: var(--text);
    background: var(--highlight);
  }

  .navbar-brand {
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
    flex-shrink: 0;
    transition: opacity var(--transition-fast);
  }

  .navbar-brand:hover {
    opacity: 0.7;
  }

  .brand-dot {
    color: var(--accent);
  }

  .navbar-search {
    display: flex;
    align-items: center;
    flex: 1;
    max-width: 400px;
    height: 34px;
    padding: 0 var(--spacing-sm) 0 var(--spacing-md);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    gap: var(--spacing-sm);
  }

  .navbar-search:focus-within {
    border-color: var(--text-muted);
    box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.04);
  }

  .search-icon {
    color: var(--text-faint);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    border: none;
    background: none;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text);
    outline: none;
    min-width: 0;
  }

  .search-input::placeholder {
    color: var(--text-faint);
  }

  .search-shortcut {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.1em 0.45em;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-faint);
    background: var(--bg-secondary);
    flex-shrink: 0;
    line-height: 1.5;
  }

  .navbar-icons {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    flex-shrink: 0;
  }

  .nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: var(--radius-md);
    color: var(--text-muted);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav-icon:hover {
    color: var(--text);
    background: var(--highlight);
  }

  @media (max-width: 600px) {
    .navbar-search {
      max-width: 200px;
    }
    
    .search-shortcut {
      display: none;
    }
  }
</style>

<script>
  // Keyboard shortcut: "/" to focus search
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement?.tagName !== 'INPUT') {
      e.preventDefault();
      document.getElementById('search-input')?.focus();
    }
    if (e.key === 'Escape') {
      (document.getElementById('search-input') as HTMLInputElement)?.blur();
    }
  });

  // Mobile menu toggle
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.querySelector('.sidebar')?.classList.toggle('is-open');
    document.getElementById('sidebar-backdrop')?.classList.toggle('is-open');
  });
</script>
