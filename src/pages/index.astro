---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Group by subject for display
const subjects = [...new Set(posts.map(p => p.data.subject))];
---

<BaseLayout title="blog. — A minimalistic blog" description="A minimalistic blog about code, systems, and ideas.">
  <Navbar />
  <div class="page-layout">
    <Sidebar />
    <main class="main-content">
      <div class="home-content animate-fade-in">
        <header class="home-header">
          <h1 class="home-title">Notes & Thoughts</h1>
          <p class="home-subtitle">
            A collection of notes on programming, systems, and computer science.
          </p>
        </header>

        <div class="posts-grid">
          {posts.map((post, index) => (
            <a href={`/blog/${post.id}`} class="post-card" id={`post-card-${post.id}`} style={`animation-delay: ${index * 60}ms`}>
              <div class="post-card-inner">
                <div class="post-card-meta">
                  <span class="post-subject">{post.data.subject}</span>
                  <span class="post-date">
                    {post.data.date.toLocaleDateString('en-US', { 
                      month: 'short', 
                      day: 'numeric',
                      year: 'numeric'
                    })}
                  </span>
                </div>
                <h2 class="post-card-title">{post.data.title}</h2>
                <p class="post-card-desc">{post.data.description}</p>
                <span class="post-card-link">
                  Read more
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
        <Footer />
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .home-content {
    max-width: 640px;
  }

  .home-header {
    margin-bottom: var(--spacing-2xl);
    padding-bottom: var(--spacing-xl);
    border-bottom: 1px solid var(--border-light);
  }

  .home-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: var(--spacing-sm);
    line-height: var(--line-height-tight);
  }

  .home-subtitle {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: var(--line-height);
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .post-card {
    display: block;
    padding: var(--spacing-lg) 0;
    border-bottom: 1px solid var(--border-light);
    transition: background var(--transition-fast);
    animation: fadeIn 0.4s ease forwards;
    opacity: 0;
    margin: 0 calc(-1 * var(--spacing-md));
    padding-left: var(--spacing-md);
    padding-right: var(--spacing-md);
    border-radius: var(--radius-md);
  }

  .post-card:first-child {
    border-top: none;
  }

  .post-card:hover {
    background: var(--highlight);
  }

  .post-card-inner {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .post-subject {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
  }

  .post-date {
    font-size: var(--text-xs);
    color: var(--text-faint);
  }

  .post-card-title {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    line-height: var(--line-height-tight);
  }

  .post-card-desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--line-height);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-faint);
    transition: color var(--transition-fast), gap var(--transition-fast);
    margin-top: var(--spacing-xs);
  }

  .post-card:hover .post-card-link {
    color: var(--accent);
    gap: 8px;
  }

</style>
